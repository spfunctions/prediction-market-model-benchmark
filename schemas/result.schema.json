  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "model": { "type": "string" },
    "task_id": { "type": "string" },
    "status": { "enum": ["not_run", "ok", "error"] },
    "output": { "type": ["string", "null"] },
    "score": { "type": ["number", "null"] },
    "metadata": { "type": "object" }
  }
}
